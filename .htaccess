# ============================================================================
# Security headers — sent on every response.
# ============================================================================
<IfModule mod_headers.c>
  # Don't let browsers MIME-sniff a response into a different content type.
  Header always set X-Content-Type-Options "nosniff"
  # Clickjacking: the site may not be framed by other origins.
  Header always set X-Frame-Options "SAMEORIGIN"
  # Only send the origin (not the full path) as referrer to other sites.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Disable powerful browser features the site never uses.
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"
  # Force HTTPS for a year once seen (Hostinger serves the site over SSL).
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Content Security Policy. Allowlists only the third parties the site actually
  # uses: Google Fonts (storefront), Google Analytics (consent-gated), Google
  # Identity Services + the GitHub API (admin panel only). 'unsafe-inline' is
  # required because the pages are built with inline <script>/<style>; the policy
  # still blocks scripts/connections/frames from any other origin.
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: https://www.google-analytics.com https://www.gstatic.com; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://accounts.google.com https://apis.google.com https://www.gstatic.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://api.github.com https://accounts.google.com; frame-src https://accounts.google.com;"
</IfModule>

# ============================================================================
# Block access to dotfiles and internal files (defense in depth — the deploy
# already excludes .git/.github, but never serve them even if present).
# ============================================================================
<FilesMatch "(^\.|~$|\.(bak|old|orig|save|swp|dist|log|sh|json)$)">
  Require all denied
</FilesMatch>
# …but the site's real, intentionally-public JSON needs to stay reachable.
<FilesMatch "^(site|admin)\.webmanifest$">
  Require all granted
</FilesMatch>
<Files "sitemap.xml">
  Require all granted
</Files>
<Files ".ftp-deploy-sync-state.json">
  Require all denied
</Files>

# ============================================================================
# Clean URLs — serve pages without the .html extension, and use /inicio for home
# (e.g. escenabmx.com/tienda, escenabmx.com/producto/<slug>, escenabmx.com/inicio)
# ============================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Bare domain root -> /inicio (single canonical home URL)
  RewriteCond %{THE_REQUEST} \s/+(\?[^\s]*)?\s [NC]
  RewriteRule ^$ /inicio [R=301,L]

  # index or index.html -> /inicio
  RewriteCond %{THE_REQUEST} \s/+index(\.html)?(\?[^\s]*)?\s [NC]
  RewriteRule ^ /inicio [R=301,L]

  # Any explicit .html request -> extensionless (query string preserved)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(\?[^\s]*)?\s [NC]
  RewriteRule ^ /%1 [R=301,L]

  # /inicio -> index.html (internal, no redirect)
  RewriteRule ^inicio/?$ index.html [L]

  # Extensionless -> .html when that file exists (internal, no redirect)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# HTML pages: never cache — ensures visitors always get the latest version
# even when Hostinger's CDN (Cloudflare) is active.
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# Static assets (.js, .css, images): cache for 1 year.
# Cache-busting is handled by version query strings (?v=N) in the HTML.
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|woff2|woff|ttf)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
